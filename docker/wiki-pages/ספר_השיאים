== מלכי השערים ==
<div class="wiki7-records__section">
{| class="wiki7-records__table"
! #
! שחקן
! שערים
|-
{{#cargo_query:
tables=player_stats
|fields=player_id,SUM(goals)=total_goals
|group by=player_id
|having=SUM(goals) > 0
|order by=total_goals DESC
|limit=20
|format=template
|template=Record row
|named args=yes
}}
|}
</div>

