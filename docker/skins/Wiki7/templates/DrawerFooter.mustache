{{#has-drawer-footer-items}}
<footer class="wiki7-drawer__footer">
    <div class="wiki7-drawer__footer-links">
        {{#array-drawer-footer-items}}
        <a href="{{href}}" class="wiki7-drawer__footer-link wiki7-drawer__footer-link--{{icon}}" title="{{label}}" aria-label="{{label}}" {{#external}}target="_blank" rel="noopener"{{/external}}>
            <span class="wiki7-drawer__footer-icon"></span>
        </a>
        {{/array-drawer-footer-items}}
    </div>
</footer>
{{/has-drawer-footer-items}}
